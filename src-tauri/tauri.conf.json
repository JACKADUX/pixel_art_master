{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pixelart-master",
  "version": "0.1.0",
  "identifier": "com.administrator.pixelart-master",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PixelArt Master",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost blob: data:; connect-src 'self' ipc: http://ipc.localhost https: http://localhost:* http://127.0.0.1:* ws://localhost:* ws://127.0.0.1:* wss:",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**/tauri-plugin-screenshots/**",
          "$PICTURE/**",
          "$DOWNLOAD/**",
          "$DOCUMENT/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
